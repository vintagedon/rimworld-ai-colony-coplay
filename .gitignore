# ============================================================================
# .gitignore for RimWorld AI Colony Co-Play
# ============================================================================

# ----------------------------------------------------------------------------
# PROJECT-SPECIFIC
# ----------------------------------------------------------------------------
# State output (track structure, ignore extracted data)
state/snapshots/*
state/history/*
!state/snapshots/.gitkeep
!state/history/.gitkeep

# Game saves (large binary files)
game-saves/**/*.rws

# Reference data (real game data used for testing)
.reference-data/

# ----------------------------------------------------------------------------
# SECRETS & CREDENTIALS
# ----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets/
credentials/
config.local.*
*.secrets

# ----------------------------------------------------------------------------
# VAULT / AGENT WORKFLOW
# ----------------------------------------------------------------------------
*-pending.md
staging/
spec/
internal-files/

# ----------------------------------------------------------------------------
# IDE & EDITOR
# ----------------------------------------------------------------------------
.vscode/
.idea/
.markdownlint.json
cspell.json
*.swp
*.swo
*~
.project

# ----------------------------------------------------------------------------
# PYTHON
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
ENV/
env/
.conda/
conda-env/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Testing
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# ----------------------------------------------------------------------------
# BUILD & DOCUMENTATION
# ----------------------------------------------------------------------------
docs/_build/
site/
*.log
*.tmp
*.temp

# ----------------------------------------------------------------------------
# OS GENERATED
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# LARGE FILES
# ----------------------------------------------------------------------------
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar

# ----------------------------------------------------------------------------
# MISC
# ----------------------------------------------------------------------------
*.bak
*.backup
tmp/
temp/
scratch/
local/
.local/
*.local
